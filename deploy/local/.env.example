# FastClaw 真实密钥模板. 复制为 .env 后填值. .env 已被 .gitignore.
# 加载方式: deploy/local/secrets.sh (从 .env 读 -> kubectl create secret)
#
# ─── OPENAI / 其他 LLM provider key 不在这里 ───
# fastclaw agents init 会从调用进程的 env 读取 provider key 并存进 DB
# (agents.api_key). 每个用户/agent 独立, 不该 cluster 级共享.
#
# 用法示例 (在你自己的 shell 里, 持有 key 的人运行):
#   export OPENAI_API_KEY=sk-xxxxxxxx
#   kubectl -n fastclaw exec deploy/fastclaw -- env OPENAI_API_KEY \
#     fastclaw agents init my-agent \
#       --provider openai --model gpt-4o-mini \
#       --api-key-env OPENAI_API_KEY
# key 解析后写进 DB, pod env 可不再保留.
#
# ─── E2B key 仅在启用 sandbox 时需要 ───
# 默认 FASTCLAW_SANDBOX_ENABLED=false, 不需要 E2B key. 若启用, 取消下一行
# 注释并填值, 然后重跑 bash deploy/local/secrets.sh.
#
# E2B_API_KEY=e2b_xxxxxxxxxxxxxxxxxxxx
